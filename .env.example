# Supabase Configuration
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps API
# Get from: Google Cloud Console → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Site URL
# Use http://localhost:3000 for local development
# Set to your production URL when deploying
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend Email Service (Optional)
# Get from: https://resend.com/api-keys
# Only required if you want email notifications for submissions
RESEND_API_KEY=your-resend-api-key

# Internal API Secret
# Used to authenticate internal server-to-server API calls (e.g. email routes)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret

# Discord Webhook (Optional)
# Posts a message to a Discord channel when a new map is created.
# Create one in Discord: Channel → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL
# Leave unset to disable Discord notifications.
DISCORD_MAP_WEBHOOK_URL=

# Supabase MCP Access Token (Optional, for Claude Code)
# Get from: https://supabase.com/dashboard/account/tokens
# Only required if using Supabase MCP with Claude Code
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
INTERNAL_API_SECRET=your-internal-api-secret